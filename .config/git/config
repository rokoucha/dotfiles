[core]
    editor = vim
    pager = less

[color]
    ui = auto
    status = auto
    diff = auto
    branch = auto
    interactive = auto
    grep = auto

[credential]
    helper = 
    helper = !git-credential-manager

[url "https://github.com/"]
    insteadOf = ssh://git@github.com/
    insteadOf = git@github.com:

[ghq]
    root = ~/Projects

[ghq "https://github.com/"]
    vcs = git

[alias]
    tree = log --graph --format=\"%x09%C(cyan bold)%an%Creset%x09%C(yellow)%h%Creset %C(magenta reverse)%d%Creset %s\"

[init]
    defaultBranch = main

[push]
    autoSetupRemote = true

[branch]
    autoSetupMerge = false

[pull]
    ff = only

[include]
    path = config.local
